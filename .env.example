# Manager Site API
MANAGER_API_URL=http://localhost:3005
MONITOR_API_KEY=your-monitor-api-key-here

# Dead Checker Job
# Interval between checks (milliseconds) - default 60 seconds
DEAD_CHECKER_INTERVAL_MS=60000
# Note: Stale threshold now uses each tool's estimateTime (default 5 min if null)

# Logging (debug, info, warn, error)
LOG_LEVEL=info
